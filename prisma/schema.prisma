// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
//
// Database: PostgreSQL (Neon) — production and local dev use the same Neon database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Carteira enum ─────────────────────────────────
// Explicit carteira stored on each Cliente record.
// No longer computed from vendedorId + system users.

enum Carteira {
  SEM_VENDEDOR
  BOLSAO
  LISTA_FRIA
  FORNECEDOR
  COM_VENDEDOR
}

// ─── Unified Cliente table ─────────────────────────
// All client data lives here, regardless of source (XLSX import, Google Sheets, manual)
// The `source` field tracks origin: "xlsx" | "sheets" | "manual"

model Cliente {
  id                String  @id @default(cuid())
  codigo            String  @unique
  ieRg              String  @default("")
  razaoSocial       String  @default("")
  nomeFantasia      String  @default("")
  situacaoCadastral String  @default("")
  cnpj              String  @default("")
  endereco          String  @default("")
  numero            String  @default("")
  complemento       String  @default("")
  bairro            String  @default("")
  cidade            String  @default("")
  cep               String  @default("")
  uf                String  @default("")
  telefone1         String  @default("")
  telefone2         String  @default("")
  telefone3         String  @default("")
  telefone4         String  @default("")
  email1            String  @default("")
  email2            String  @default("")
  email3            String  @default("")
  pessoaContato     String  @default("")
  dataSituacao      String  @default("")
  dataAbertura      String  @default("")
  cnaePrincipal     String  @default("")
  naturezaJuridica  String  @default("")
  porte             String  @default("")
  cadastro          String  @default("")
  ultimaVenda       String  @default("")
  regSimples        String  @default("")
  vendedor          String  @default("")
  observacoes       String  @default("")  @db.Text
  source            String  @default("manual")   // "xlsx" | "sheets" | "manual"
  sheetsRow         Int     @default(0)           // Row number in Google Sheets (for sync)

  // ─── Tipo ─────────────────────────────────────
  // tipo: "REVENDA" | "CORPORATIVO"
  tipo                       String   @default("REVENDA")

  // ─── Fornecedor ───────────────────────────────
  fornecedor                 Boolean  @default(false)

  // ─── Carteira (explicit field, no longer computed) ──
  carteira                   Carteira @default(SEM_VENDEDOR)

  // ─── Vendedor assignment ──────────────────────
  // vendedorId is only set when carteira = COM_VENDEDOR (real vendor assigned)
  vendedorId                 String?  // FK → User.id (real vendor only, not system user)
  dataAtribuicaoVendedor     DateTime?  // When current vendedor was assigned
  dataEntradaBolsao          DateTime?
  vendedoresQueAbordaram     String   @default("")  @db.Text  // comma-separated User IDs who approached

  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())

  vendedorUser User? @relation("VendedorClientes", fields: [vendedorId], references: [id], onDelete: SetNull)
  favorites   Favorite[]

  @@index([cnpj])
  @@index([cidade])
  @@index([uf])
  @@index([vendedor])
  @@index([situacaoCadastral])
  @@index([source])
  @@index([tipo])
  @@index([vendedorId])
  @@index([carteira])
}

// ─── User / Authentication ────────────────────────

model User {
  id               String   @id @default(cuid())
  name             String
  email            String   @unique
  password         String                          // bcrypt hash
  role             String   @default("VENDEDOR")   // ADMIN | DIRETOR_COMERCIAL | GERENTE_COMERCIAL | VENDEDOR
  active           Boolean  @default(true)
  twoFactorSecret  String?                          // TOTP secret (base32), null = 2FA not set up
  twoFactorEnabled Boolean  @default(false)
  imagem           String?  @default("")            // avatar URL or base64
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  clientes  Cliente[]  @relation("VendedorClientes")
  favorites  Favorite[]

  @@index([email])
  @@index([role])
}

// ─── Google Sheets Sync Config ─────────────────────

model SyncConfig {
  id              String   @id @default(cuid())
  sheetsUrl       String   @default("")         @db.Text  // Full Google Sheets URL
  spreadsheetId   String   @default("")         // Extracted spreadsheet ID
  sheetName       String   @default("Sheet1")   // Tab/sheet name
  connected       Boolean  @default(false)
  lastSyncAt      DateTime?
  lastSyncStatus  String   @default("")         // "success" | "error" | "partial"
  lastSyncCount   Int      @default(0)          // Records synced
  lastSyncError   String   @default("")         @db.Text
  headerRow       Int      @default(1)          // Row number of headers (1-indexed)
  dataStartRow    Int      @default(2)          // First data row (1-indexed)
  columnMapping   String   @default("{}")       @db.Text  // JSON: sheets col → DB field mapping
  syncMode        String   @default("pull")     // "pull" | "push" | "bidirectional"
  autoSync        Boolean  @default(false)      // Auto-sync on interval
  autoSyncMinutes Int      @default(30)         // Minutes between auto-syncs
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Audit Log ─────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  codigo     String
  field      String
  oldValue   String   @default("")  @db.Text
  newValue   String   @default("")  @db.Text
  changedBy  String   @default("user")
  source     String   @default("ui")       // "ui" | "sheets-sync"
  createdAt  DateTime @default(now())

  @@index([codigo])
  @@index([createdAt])
}

// ─── Favorites ────────────────────────────────────
// Each user can favorite up to 50 clients

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  codigo    String
  ordem     Int      @default(0)    // Order within favorites (0 = first)
  createdAt DateTime @default(now())

  user  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  cliente Cliente @relation(fields: [codigo], references: [codigo], onDelete: Cascade)

  @@unique([userId, codigo])
  @@index([userId])
  @@index([userId, ordem])
}

// ─── Permissions ──────────────────────────────────
// Dynamic permission system with DB-backed overrides per role

model Permission {
  id          String  @id @default(cuid())
  key         String  @unique           // e.g. "clients.export"
  description String  @default("")      // Human-readable description
  category    String  @default("geral") // Grouping: "clientes" | "bolsao" | "users" | "sheets" | "geral"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]

  @@index([category])
}

model RolePermission {
  id             String   @id @default(cuid())
  role           String                       // ADMIN | DIRETOR_COMERCIAL | GERENTE_COMERCIAL | VENDEDOR
  permissionKey  String                       // FK → Permission.key
  allowed        Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  permission Permission @relation(fields: [permissionKey], references: [key], onDelete: Cascade)

  @@unique([role, permissionKey])
  @@index([role])
}
