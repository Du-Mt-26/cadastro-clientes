// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
//
// Database: PostgreSQL (Neon) — production and local dev use the same Neon database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Carteira enum ─────────────────────────────────
// Explicit carteira stored on each Cliente record.
// No longer computed from vendedorId + system users.

enum Carteira {
  SEM_VENDEDOR
  BOLSAO
  LISTA_FRIA
  FORNECEDOR
  COM_VENDEDOR
}

// ─── Unified Cliente table ─────────────────────────
// All client data lives here, regardless of source (XLSX import, Google Sheets, manual)
// The `source` field tracks origin: "xlsx" | "sheets" | "manual"

model Cliente {
  id                String  @id @default(cuid())
  codigo            String  @unique
  ieRg              String  @default("")
  razaoSocial       String  @default("")
  nomeFantasia      String  @default("")
  situacaoCadastral String  @default("")
  cnpj              String  @default("")
  cnpjBase          String  @default("")         // Primeiros 8 dígitos do CNPJ (identifica a empresa base para filiais)
  endereco          String  @default("")
  numero            String  @default("")
  complemento       String  @default("")
  bairro            String  @default("")
  cidade            String  @default("")
  cep               String  @default("")
  uf                String  @default("")
  telefone1         String  @default("")
  telefone2         String  @default("")
  telefone3         String  @default("")
  telefone4         String  @default("")
  email1            String  @default("")
  email2            String  @default("")
  email3            String  @default("")
  pessoaContato     String  @default("")
  dataSituacao      String  @default("")
  dataAbertura      String  @default("")
  cnaePrincipal     String  @default("")
  naturezaJuridica  String  @default("")
  porte             String  @default("")
  cadastro          String  @default("")
  ultimaVenda       String  @default("")
  regSimples        String  @default("")
  vendedor          String  @default("")
  observacoes       String  @default("")  @db.Text
  source            String  @default("manual")   // "xlsx" | "sheets" | "manual"
  sheetsRow         Int     @default(0)           // Row number in Google Sheets (for sync)

  // ─── Tipo ─────────────────────────────────────
  // tipo: "REVENDA" | "CORPORATIVO"
  tipo                       String   @default("REVENDA")

  // ─── Fornecedor ───────────────────────────────
  fornecedor                 Boolean  @default(false)

  // ─── Carteira (explicit field, no longer computed) ──
  carteira                   Carteira @default(SEM_VENDEDOR)

  // ─── Vendedor assignment ──────────────────────
  // vendedorId is only set when carteira = COM_VENDEDOR (real vendor assigned)
  vendedorId                 String?  // FK → User.id (real vendor only, not system user)
  dataAtribuicaoVendedor     DateTime?  // When current vendedor was assigned
  dataEntradaBolsao          DateTime?
  vendedoresQueAbordaram     String   @default("")  @db.Text  // comma-separated User IDs who approached

  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())

  vendedorUser User? @relation("VendedorClientes", fields: [vendedorId], references: [id], onDelete: SetNull)
  favorites   Favorite[]
  vendas      Venda[]

  @@index([cnpj])
  @@index([cnpjBase])
  @@index([cidade])
  @@index([uf])
  @@index([vendedor])
  @@index([situacaoCadastral])
  @@index([source])
  @@index([tipo])
  @@index([vendedorId])
  @@index([carteira])
}

// ─── User / Authentication ────────────────────────

model User {
  id               String   @id @default(cuid())
  name             String
  email            String   @unique
  password         String                          // bcrypt hash
  role             String   @default("VENDEDOR")   // ADMIN | DIRETOR_COMERCIAL | GERENTE_COMERCIAL | VENDEDOR
  active           Boolean  @default(true)
  twoFactorSecret  String?                          // TOTP secret (base32), null = 2FA not set up
  twoFactorEnabled Boolean  @default(false)
  imagem           String?  @default("")            // avatar URL or base64
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  clientes  Cliente[]  @relation("VendedorClientes")
  favorites  Favorite[]

  @@index([email])
  @@index([role])
}

// ─── Google Sheets Sync Config ─────────────────────

model SyncConfig {
  id              String   @id @default(cuid())
  sheetsUrl       String   @default("")         @db.Text  // Full Google Sheets URL
  spreadsheetId   String   @default("")         // Extracted spreadsheet ID
  sheetName       String   @default("Sheet1")   // Tab/sheet name
  connected       Boolean  @default(false)
  lastSyncAt      DateTime?
  lastSyncStatus  String   @default("")         // "success" | "error" | "partial"
  lastSyncCount   Int      @default(0)          // Records synced
  lastSyncError   String   @default("")         @db.Text
  headerRow       Int      @default(1)          // Row number of headers (1-indexed)
  dataStartRow    Int      @default(2)          // First data row (1-indexed)
  columnMapping   String   @default("{}")       @db.Text  // JSON: sheets col → DB field mapping
  syncMode        String   @default("pull")     // "pull" | "push" | "bidirectional"
  autoSync        Boolean  @default(false)      // Auto-sync on interval
  autoSyncMinutes Int      @default(30)         // Minutes between auto-syncs
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Audit Log ─────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  codigo     String
  field      String
  oldValue   String   @default("")  @db.Text
  newValue   String   @default("")  @db.Text
  changedBy  String   @default("user")
  source     String   @default("ui")       // "ui" | "sheets-sync"
  createdAt  DateTime @default(now())

  @@index([codigo])
  @@index([createdAt])
}

// ─── Favorites ────────────────────────────────────
// Each user can favorite up to 50 clients

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  codigo    String
  ordem     Int      @default(0)    // Order within favorites (0 = first)
  createdAt DateTime @default(now())

  user  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  cliente Cliente @relation(fields: [codigo], references: [codigo], onDelete: Cascade)

  @@unique([userId, codigo])
  @@index([userId])
  @@index([userId, ordem])
}

// ─── Permissions ──────────────────────────────────
// Dynamic permission system with DB-backed overrides per role

model Permission {
  id          String  @id @default(cuid())
  key         String  @unique           // e.g. "clients.export"
  description String  @default("")      // Human-readable description
  category    String  @default("geral") // Grouping: "clientes" | "bolsao" | "users" | "sheets" | "geral"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]

  @@index([category])
}

model RolePermission {
  id             String   @id @default(cuid())
  role           String                       // ADMIN | DIRETOR_COMERCIAL | GERENTE_COMERCIAL | VENDEDOR
  permissionKey  String                       // FK → Permission.key
  allowed        Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  permission Permission @relation(fields: [permissionKey], references: [key], onDelete: Cascade)

  @@unique([role, permissionKey])
  @@index([role])
}

// ─── Linvix Sync Log ────────────────────────────────
// Tracks each Linvix → M-Tech sync execution

model LinvixSyncLog {
  id              String   @id @default(cuid())
  syncType        String   @default("clientes")  // "clientes" | "vendas" | "all"
  status          String   @default("running")    // "running" | "success" | "error" | "partial"
  startedAt       DateTime @default(now())
  finishedAt      DateTime?
  totalClients    Int      @default(0)            // Total records found in Linvix (clients or NF-e)
  createdCount    Int      @default(0)            // New records created in M-Tech
  updatedCount    Int      @default(0)            // Existing records updated in M-Tech
  skippedCount    Int      @default(0)            // Records skipped (no changes / already synced)
  errorCount      Int      @default(0)            // Errors during sync
  errorMessage    String   @default("")  @db.Text
  pagesScraped    Int      @default(0)            // Number of Linvix pages scraped
  detailsScraped  Int      @default(0)            // Number of detail pages visited
  durationMs      Int      @default(0)            // Total sync duration in ms

  @@index([startedAt])
  @@index([status])
  @@index([syncType])
}

// ─── Venda (NF-e) ────────────────────────────────
// Sincronizado do Linvix ERP → M-Tech (unidirecional)
// Apenas dados comerciais — tributação não é importada por enquanto

model Venda {
  id                String   @id @default(cuid())
  linvixId          Int      @unique              // ID interno do Linvix
  uuid              String   @default("")         // UUID da NF-e
  faturamento       Int      @default(0)          // Nº do faturamento Linvix
  numeroPedido      Int      @default(0)          // Nº do pedido originário
  numero            String   @default("")         // Número da NF-e
  serie             String   @default("1")        // Série da NF-e
  clienteCodigo     String                        // FK → Cliente.codigo
  finalidade        String   @default("")         // "1 - NORMAL", "2 - COMPLEMENTAR", etc.
  situacao          String   @default("")         // "AUTORIZADO", "CANCELAMENTO", "AGUARDANDO", etc.
  valorTotal        Float    @default(0)          // Valor total da nota
  dataEmissao       DateTime?                     // Data/hora de emissão
  dataSaida         DateTime?                     // Data/hora de saída
  operador          String   @default("")         // Quem emitiu a NF-e
  naturezaOperacao  String   @default("")         // "VENDA DE MERCADORIAS..."
  emitente          String   @default("")         // Emitente (M-TECH ou RP)
  chave             String   @default("")         // Chave de acesso NF-e
  transportadora    String   @default("")         // Nome da transportadora
  devolvido         Boolean  @default(false)       // Se foi devolvido
  observacoes       String   @default("")  @db.Text

  // Pagamento (resumo financeiro)
  valorVenda        Float    @default(0)
  valorPago         Float    @default(0)
  valorProdutos     Float    @default(0)
  valorFrete        Float    @default(0)
  valorDesconto     Float    @default(0)
  valorFinal        Float    @default(0)
  formaPagamento    String   @default("")         // "12x Sem Juros", "À Vista", etc.

  // Sync metadata
  source            String   @default("linvix")   // Sempre "linvix"
  syncedAt          DateTime @default(now())      // Quando foi sincronizado
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relações
  cliente           Cliente  @relation(fields: [clienteCodigo], references: [codigo], onDelete: Cascade)
  itens             VendaItem[]

  @@index([clienteCodigo])
  @@index([dataEmissao])
  @@index([situacao])
  @@index([numero])
  @@index([faturamento])
}

// ─── Itens da Venda (Produtos da NF-e) ──────────

model VendaItem {
  id                String   @id @default(cuid())
  vendaId           String                        // FK → Venda.id
  item              Int      @default(0)          // Número do item na NF-e
  codigoProduto     String   @default("")         // Código do produto
  descricao         String   @default("")         // Descrição do produto
  unidade           String   @default("")         // UND, PC, etc.
  quantidade        Float    @default(0)          // Quantidade
  precoVenda        Float    @default(0)          // Preço unitário
  valorDesconto     Float    @default(0)          // Desconto total
  valorCusto        Float    @default(0)          // Custo unitário
  valorTotal        Float    @default(0)          // Valor total do item
  vendedor          String   @default("")         // Vendedor do item
  ncm               String   @default("")         // Código NCM
  cfop              String   @default("")         // CFOP

  createdAt         DateTime @default(now())

  // Relação
  venda             Venda    @relation(fields: [vendaId], references: [id], onDelete: Cascade)

  @@index([vendaId])
  @@index([codigoProduto])
}
