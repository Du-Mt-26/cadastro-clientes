// SQLite schema for LOCAL DEVELOPMENT only.
// Production uses PostgreSQL (Neon) — see schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Cliente {
  id                String  @id @default(cuid())
  codigo            String  @unique
  ieRg              String  @default("")
  razaoSocial       String  @default("")
  nomeFantasia      String  @default("")
  situacaoCadastral String  @default("")
  cnpj              String  @default("")
  endereco          String  @default("")
  numero            String  @default("")
  complemento       String  @default("")
  bairro            String  @default("")
  cidade            String  @default("")
  cep               String  @default("")
  uf                String  @default("")
  telefone1         String  @default("")
  telefone2         String  @default("")
  telefone3         String  @default("")
  telefone4         String  @default("")
  email1            String  @default("")
  email2            String  @default("")
  email3            String  @default("")
  pessoaContato     String  @default("")
  dataSituacao      String  @default("")
  dataAbertura      String  @default("")
  cnaePrincipal     String  @default("")
  naturezaJuridica  String  @default("")
  porte             String  @default("")
  cadastro          String  @default("")
  ultimaVenda       String  @default("")
  regSimples        String  @default("")
  vendedor          String  @default("")
  observacoes       String  @default("")
  source            String  @default("manual")
  sheetsRow         Int     @default(0)

  carteira                   String   @default("CARTEIRA_ATUAL")
  vendedorId                 String?
  dataEntradaBolsao          DateTime?
  dataEntradaCarteiraFria    DateTime?
  vendedoresQueAbordaram     String   @default("")

  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())

  @@index([cnpj])
  @@index([cidade])
  @@index([uf])
  @@index([vendedor])
  @@index([situacaoCadastral])
  @@index([source])
  @@index([carteira])
  @@index([vendedorId])
}

model User {
  id               String   @id @default(cuid())
  name             String
  email            String   @unique
  password         String
  role             String   @default("VENDEDOR")
  active           Boolean  @default(true)
  twoFactorSecret  String?
  twoFactorEnabled Boolean  @default(false)
  imagem           String?  @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([email])
  @@index([role])
}

model SyncConfig {
  id              String   @id @default(cuid())
  sheetsUrl       String   @default("")
  spreadsheetId   String   @default("")
  sheetName       String   @default("Sheet1")
  connected       Boolean  @default(false)
  lastSyncAt      DateTime?
  lastSyncStatus  String   @default("")
  lastSyncCount   Int      @default(0)
  lastSyncError   String   @default("")
  headerRow       Int      @default(1)
  dataStartRow    Int      @default(2)
  columnMapping   String   @default("{}")
  syncMode        String   @default("pull")
  autoSync        Boolean  @default(false)
  autoSyncMinutes Int      @default(30)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  codigo     String
  field      String
  oldValue   String   @default("")
  newValue   String   @default("")
  changedBy  String   @default("user")
  source     String   @default("ui")
  createdAt  DateTime @default(now())

  @@index([codigo])
  @@index([createdAt])
}
